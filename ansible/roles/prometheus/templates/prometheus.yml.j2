# {{ ansible_managed }}
global:
  scrape_interval: {{ prometheus_scrape_interval }}

scrape_configs:
  # Prometheus tự giám sát chính nó.
  # Vì đặt --web.route-prefix={{ prometheus_route_prefix }}, endpoint metrics của
  # chính nó cũng nằm dưới prefix -> phải khai báo metrics_path cho khớp.
  - job_name: "prometheus"
    metrics_path: "{{ prometheus_route_prefix }}/metrics"
    static_configs:
      - targets: ["localhost:{{ prometheus_http_port }}"]

  # node_exporter trên web server (IP lấy tự động từ inventory group 'web')
  - job_name: "node-web"
    static_configs:
      - targets: ["{{ hostvars[groups['web'][0]].ansible_host }}:{{ node_exporter_port }}"]
        labels:
          instance: "web"

  # node_exporter trên app server / Jenkins (IP lấy từ inventory group 'app')
  - job_name: "node-app"
    static_configs:
      - targets: ["{{ hostvars[groups['app'][0]].ansible_host }}:{{ node_exporter_port }}"]
        labels:
          instance: "app"
